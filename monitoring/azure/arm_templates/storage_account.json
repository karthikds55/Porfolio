{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys a Storage Account for pipeline log archiving. Replaces AWS S3 bucket 'ecommerce-pipeline-logs-archive'.",
    "migratedFrom": "AWS S3 bucket: ecommerce-pipeline-logs-archive (prefix: cloudwatch-exports/)"
  },
  "parameters": {
    "storageAccountName": {
      "type": "string",
      "defaultValue": "stecommercepipelinelogs",
      "maxLength": 24,
      "metadata": {"description": "Must be globally unique, 3–24 chars, lowercase alphanumeric only."}
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "sku": {
      "type": "string",
      "defaultValue": "Standard_LRS",
      "allowedValues": ["Standard_LRS", "Standard_GRS", "Standard_ZRS"]
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "project": "ecommerce-orders-pipeline",
        "environment": "production",
        "migrated_from": "aws"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "kind": "StorageV2",
      "sku": {"name": "[parameters('sku')]"},
      "tags": "[parameters('tags')]",
      "properties": {
        "accessTier": "Hot",
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "networkAcls": {"defaultAction": "Allow"}
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-01-01",
      "name": "[concat(parameters('storageAccountName'), '/default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ],
      "properties": {
        "deleteRetentionPolicy": {"enabled": true, "days": 7},
        "containerDeleteRetentionPolicy": {"enabled": true, "days": 7}
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-01-01",
      "name": "[concat(parameters('storageAccountName'), '/default/pipeline-logs')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', parameters('storageAccountName'), 'default')]"
      ],
      "properties": {"publicAccess": "None"}
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-01-01",
      "name": "[concat(parameters('storageAccountName'), '/default/diagnostic-exports')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', parameters('storageAccountName'), 'default')]"
      ],
      "properties": {"publicAccess": "None"}
    },
    {
      "type": "Microsoft.Storage/storageAccounts/managementPolicies",
      "apiVersion": "2023-01-01",
      "name": "[concat(parameters('storageAccountName'), '/default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ],
      "properties": {
        "policy": {
          "rules": [
            {
              "name": "pipeline-logs-lifecycle",
              "enabled": true,
              "type": "Lifecycle",
              "definition": {
                "filters": {"blobTypes": ["blockBlob"], "prefixMatch": ["pipeline-logs/"]},
                "actions": {
                  "baseBlob": {
                    "tierToCool":    {"daysAfterModificationGreaterThan": 7},
                    "tierToArchive": {"daysAfterModificationGreaterThan": 30},
                    "delete":        {"daysAfterModificationGreaterThan": 90}
                  }
                }
              }
            },
            {
              "name": "diagnostic-exports-lifecycle",
              "enabled": true,
              "type": "Lifecycle",
              "definition": {
                "filters": {"blobTypes": ["blockBlob"], "prefixMatch": ["diagnostic-exports/"]},
                "actions": {
                  "baseBlob": {
                    "tierToCool": {"daysAfterModificationGreaterThan": 14},
                    "delete":     {"daysAfterModificationGreaterThan": 365}
                  }
                }
              }
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "storageAccountId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
    },
    "primaryBlobEndpoint": {
      "type": "string",
      "value": "[reference(parameters('storageAccountName')).primaryEndpoints.blob]"
    }
  }
}
