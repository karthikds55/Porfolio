{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys an Azure Portal shared dashboard for the e-commerce orders pipeline. Surfaces pipeline run status, quality check results, record counts, and alert state.",
    "migrated_from": "AWS CloudWatch Dashboard"
  },
  "parameters": {
    "dashboardName": {
      "type": "string",
      "defaultValue": "dash-ecommerce-pipeline"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "appInsightsId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the Application Insights component."
      }
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the Log Analytics Workspace."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "project": "ecommerce-orders-pipeline",
        "environment": "production"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Portal/dashboards",
      "apiVersion": "2020-09-01-preview",
      "name": "[parameters('dashboardName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "lenses": [
          {
            "order": 0,
            "parts": [
              {
                "position": { "x": 0, "y": 0, "colSpan": 12, "rowSpan": 1 },
                "metadata": {
                  "type": "Extension/HubsExtension/PartType/MarkdownPart",
                  "settings": {
                    "content": {
                      "settings": {
                        "content": "## E-Commerce Orders Pipeline – Azure Monitor\nMigrated from AWS CloudWatch. Real-time pipeline health, data quality, and alert state.",
                        "title": "",
                        "subtitle": ""
                      }
                    }
                  }
                }
              },
              {
                "position": { "x": 0, "y": 1, "colSpan": 6, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "inputs": [
                    {
                      "name": "resourceTypeMode",
                      "value": "components",
                      "isOptional": true
                    },
                    {
                      "name": "ComponentId",
                      "value": { "SubscriptionId": "", "ResourceGroup": "", "Name": "", "ResourceId": "[parameters('appInsightsId')]" }
                    },
                    {
                      "name": "Query",
                      "value": "AppTraces | where Properties.event_type == 'pipeline_run' | project TimeGenerated, tostring(Properties.pipeline), tostring(Properties.status), todouble(Properties.duration_seconds), toint(Properties.record_count) | order by TimeGenerated desc | take 20"
                    },
                    {
                      "name": "TimeRange",
                      "value": "P1D"
                    }
                  ],
                  "settings": {
                    "content": { "GridColumnsWidth": {} }
                  },
                  "metadata": {
                    "modelEncodingVersion": "1.0",
                    "title": "Recent Pipeline Runs"
                  }
                }
              },
              {
                "position": { "x": 6, "y": 1, "colSpan": 6, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "inputs": [
                    {
                      "name": "ComponentId",
                      "value": { "ResourceId": "[parameters('appInsightsId')]" }
                    },
                    {
                      "name": "Query",
                      "value": "AppTraces | where Properties.event_type == 'quality_check' | project TimeGenerated, tostring(Properties.check_name), tostring(Properties.result), tostring(Properties.details) | order by TimeGenerated desc | take 30"
                    },
                    {
                      "name": "TimeRange",
                      "value": "P1D"
                    }
                  ],
                  "settings": {},
                  "metadata": {
                    "title": "Quality Check Results (last 24 h)"
                  }
                }
              },
              {
                "position": { "x": 0, "y": 5, "colSpan": 6, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "inputs": [
                    {
                      "name": "ComponentId",
                      "value": { "ResourceId": "[parameters('appInsightsId')]" }
                    },
                    {
                      "name": "Query",
                      "value": "AppMetrics | where Name == 'pipeline_duration_seconds' | summarize AvgDuration = avg(Sum), MaxDuration = max(Sum) by bin(TimeGenerated, 1h), tostring(Properties.pipeline) | order by TimeGenerated desc"
                    },
                    {
                      "name": "TimeRange",
                      "value": "P7D"
                    },
                    {
                      "name": "Dimensions",
                      "value": { "xAxis": { "name": "TimeGenerated", "type": "datetime" }, "yAxis": [{ "name": "AvgDuration", "type": "real" }], "splitBy": [{ "name": "Properties_pipeline", "type": "string" }] }
                    }
                  ],
                  "settings": {},
                  "metadata": {
                    "title": "Pipeline Duration Trend (7 d)"
                  }
                }
              },
              {
                "position": { "x": 6, "y": 5, "colSpan": 6, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "inputs": [
                    {
                      "name": "ComponentId",
                      "value": { "ResourceId": "[parameters('appInsightsId')]" }
                    },
                    {
                      "name": "Query",
                      "value": "AppMetrics | where Name == 'null_rate_percent' | summarize NullRate = avg(Sum) by bin(TimeGenerated, 1h), tostring(Properties.column) | order by TimeGenerated desc"
                    },
                    {
                      "name": "TimeRange",
                      "value": "P7D"
                    }
                  ],
                  "settings": {},
                  "metadata": {
                    "title": "Null Rate % by Column (7 d)"
                  }
                }
              },
              {
                "position": { "x": 0, "y": 9, "colSpan": 12, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "inputs": [
                    {
                      "name": "ComponentId",
                      "value": { "ResourceId": "[parameters('appInsightsId')]" }
                    },
                    {
                      "name": "Query",
                      "value": "AppTraces | where SeverityLevel >= 3 | project TimeGenerated, Message, tostring(Properties.pipeline), SeverityLevel | order by TimeGenerated desc | take 50"
                    },
                    {
                      "name": "TimeRange",
                      "value": "P1D"
                    }
                  ],
                  "settings": {},
                  "metadata": {
                    "title": "ERROR / WARNING Log Stream"
                  }
                }
              }
            ]
          }
        ],
        "metadata": {
          "model": {}
        }
      }
    }
  ],
  "outputs": {
    "dashboardId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Portal/dashboards', parameters('dashboardName'))]"
    }
  }
}
