# ── AWS (required for cloud/S3 mode) ─────────────────────────────────────────
AWS_REGION=us-east-1

# ── Terraform variable overrides (or set in terraform/terraform.tfvars) ───────
# RAW_BUCKET_NAME=your-org-data-engineering-raw-dev
# PARQUET_BUCKET_NAME=your-org-data-engineering-parquet-dev

# ── Cloud pipeline mode (python -m pipelines.transform with S3 source) ────────
# Set both to switch transform.py from local CSV mode to S3 Parquet mode.
# S3_STAGING_BUCKET=your-parquet-bucket-name
# S3_STAGING_KEY=orders_staging.parquet
